{
  "permissions": {
    "allow": [
      "Bash(cargo *)",
      "Bash(cargo run 2>&1 &)",
      "Bash(taskkill *)",
      "Bash(powershell -Command \"Stop-Process -Name f2filer -Force -ErrorAction SilentlyContinue\")",
      "Bash(git -C F:/dev/f2filer status)",
      "Bash(git -C F:/dev/f2filer diff)",
      "Bash(git -C F:/dev/f2filer log --oneline -5)",
      "Bash(git -C F:/dev/f2filer add CLAUDE.md src/app.rs src/config.rs src/image_viewer.rs src/main.rs src/panel.rs .claude/settings.local.json)",
      "Bash(git -C:*)",
      "Bash(timeout /t)",
      "Bash(powershell -Command \"Stop-Process -Name f2filer -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 2\")",
      "Bash(powershell -Command \"Stop-Process -Name f2filer -Force -ErrorAction SilentlyContinue; Start-Sleep -Seconds 1\")",
      "Bash(git add Cargo.toml Cargo.lock src/audio_viewer.rs src/main.rs src/app.rs src/config.rs src/dialog.rs .claude/settings.local.json)",
      "Bash(git add src/audio_viewer.rs src/app.rs .claude/settings.local.json)",
      "Bash(git commit:*)",
      "Bash(git add README.md CLAUDE.md .claude/settings.local.json)"
    ]
  }
}
